{
  "name": "@crashbytes/effect",
  "version": "1.0.2",
  "description": "Result type, retry, timeout, and structured errors for TypeScript. Zero dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "result",
    "retry",
    "timeout",
    "error",
    "structured-errors",
    "typescript",
    "effect",
    "monad",
    "try-catch",
    "backoff"
  ],
  "author": "CrashBytes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrashBytes/effect.git"
  },
  "bugs": {
    "url": "https://github.com/CrashBytes/effect/issues"
  },
  "homepage": "https://github.com/CrashBytes/effect#readme",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  }
}
